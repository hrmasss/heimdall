# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=development
GO_ENV=development

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_HOST=localhost
API_PORT=8080
API_PREFIX=/api/v1

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/heimdall?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=Heimdall

# ==============================================================================
# AUTH (future)
# ==============================================================================
JWT_SECRET=heimdall-local-dev-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
AUTH_CUSTOMER_REFRESH_COOKIE=heimdall_customer_refresh
AUTH_PLATFORM_REFRESH_COOKIE=heimdall_platform_refresh
AUTH_COOKIE_SECURE=false

# Bootstrap the first super admin if no super admin exists yet
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@heimdall.io
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# ==============================================================================
# AI/LLM CONFIGURATION (future)
# ==============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ==============================================================================
# SOCIAL INTEGRATIONS (future)
# ==============================================================================
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# YOUTUBE_API_KEY=

# ==============================================================================
# REDIS (for caching & jobs)
# ==============================================================================
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# STORAGE (future)
# ==============================================================================
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./tmp/storage
STORAGE_MAX_UPLOAD_BYTES=536870912
STORAGE_SIGNED_URL_TTL=15m
STORAGE_SIGNED_URL_SECRET=heimdall-local-dev-secret
STORAGE_OPTIMIZE_IMAGES_BY_DEFAULT=true
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
