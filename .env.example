# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=development
GO_ENV=development

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_HOST=localhost
API_PORT=8080
API_PREFIX=/api/v1

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/heimdall?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=Heimdall

# ==============================================================================
# AUTH (future)
# ==============================================================================
# JWT_SECRET=your-secret-key-change-in-production
# JWT_EXPIRY=24h

# ==============================================================================
# AI/LLM CONFIGURATION (future)
# ==============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ==============================================================================
# SOCIAL INTEGRATIONS (future)
# ==============================================================================
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# YOUTUBE_API_KEY=

# ==============================================================================
# REDIS (for caching & jobs)
# ==============================================================================
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# STORAGE (future)
# ==============================================================================
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
