# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=development
GO_ENV=development

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_HOST=localhost
API_PORT=18080
API_PREFIX=/api/v1
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/heimdall?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_API_URL=http://127.0.0.1:18080
VITE_SITE_URL=https://heimdall.social
VITE_APP_NAME=Heimdall

# ==============================================================================
# AUTH (future)
# ==============================================================================
JWT_SECRET=heimdall-local-dev-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
AUTH_CUSTOMER_REFRESH_COOKIE=heimdall_customer_refresh
AUTH_PLATFORM_REFRESH_COOKIE=heimdall_platform_refresh
AUTH_COOKIE_SECURE=false

# Bootstrap the first super admin if no super admin exists yet
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@heimdall.social
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# ==============================================================================
# AI / WORKSPACE INTELLIGENCE
# ==============================================================================
AI_ENCRYPTION_KEY=heimdall-local-ai-secret
AI_REQUEST_TIMEOUT=45s
# OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_APPROVED_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
# GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_APPROVED_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ==============================================================================
# SOCIAL INTEGRATIONS (future)
# ==============================================================================
SOCIAL_PUBLIC_API_BASE_URL=http://127.0.0.1:18080
SOCIAL_PUBLIC_ASSET_BASE_URL=http://127.0.0.1:18080
SOCIAL_ENCRYPTION_KEY=heimdall-local-social-secret
# SOCIAL_OAUTH_STATE_TTL=15m
# SOCIAL_TEMP_MEDIA_PROVIDER=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# FACEBOOK_APP_ID=
# META_CLIENT_ID=
# META_CLIENT_SECRET=
