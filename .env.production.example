# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=production
GO_ENV=production

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=18080
API_PREFIX=/api/v1
API_ALLOWED_ORIGINS=https://app.heimdall.social

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://postgres:change-me@localhost:5432/heimdall?sslmode=disable
DATABASE_MAX_CONNECTIONS=50
DATABASE_MAX_IDLE_CONNECTIONS=10

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_API_URL=https://app.heimdall.social
VITE_SITE_URL=https://app.heimdall.social
VITE_APP_NAME=Heimdall

# ==============================================================================
# AUTH
# ==============================================================================
JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
AUTH_CUSTOMER_REFRESH_COOKIE=heimdall_customer_refresh
AUTH_PLATFORM_REFRESH_COOKIE=heimdall_platform_refresh
AUTH_COOKIE_SECURE=true

# Bootstrap the first super admin if no super admin exists yet
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@heimdall.social
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# ==============================================================================
# AI / WORKSPACE INTELLIGENCE
# ==============================================================================
AI_ENCRYPTION_KEY=replace-with-long-random-secret
AI_REQUEST_TIMEOUT=45s
# OPENAI_API_KEY=
# OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_APPROVED_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
# GEMINI_API_KEY=
# GEMINI_API_KEYS=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_APPROVED_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ==============================================================================
# AUTOMATION RESEARCH
# ==============================================================================
# TAVILY_API_KEY=
# TAVILY_API_KEYS=
TAVILY_BASE_URL=https://api.tavily.com
POST_AGENT_DEFAULT_RESEARCH_DEPTH=quick

# ==============================================================================
# SOCIAL INTEGRATIONS
# ==============================================================================
SOCIAL_PUBLIC_API_BASE_URL=https://app.heimdall.social
SOCIAL_PUBLIC_ASSET_BASE_URL=https://app.heimdall.social
SOCIAL_ENCRYPTION_KEY=replace-with-long-random-secret
# SOCIAL_OAUTH_STATE_TTL=15m
# SOCIAL_TEMP_MEDIA_PROVIDER=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# FACEBOOK_APP_ID=
# META_CLIENT_ID=
# META_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# FACEBOOK_APP_SECRET=
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# YOUTUBE_API_KEY=

# ==============================================================================
# REDIS (for caching & jobs)
# ==============================================================================
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# STORAGE
# ==============================================================================
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./tmp/storage
STORAGE_MAX_UPLOAD_BYTES=536870912
STORAGE_SIGNED_URL_TTL=15m
STORAGE_SIGNED_URL_SECRET=replace-with-long-random-secret
STORAGE_OPTIMIZE_IMAGES_BY_DEFAULT=true
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ==============================================================================
# DEPLOYMENT (required by scripts/sync-production-secrets.mjs)
# ==============================================================================
DEPLOY_SSH_HOST=your.server.host
DEPLOY_SSH_USER=root
DEPLOY_SSH_PORT=22
DEPLOY_SSH_KEY_PATH=~/.ssh/id_ed25519
DEPLOY_GHCR_USERNAME=your-ghcr-username
DEPLOY_GHCR_TOKEN=your-ghcr-token
DEPLOY_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace/me
