{
  "name": "heimdall",
  "version": "0.1.0",
  "private": true,
  "description": "Centralized Social Media Management Platform",
  "workspaces": ["apps/*"],
  "scripts": {
    "predev": "node scripts/free-dev-ports.mjs 18080 5173",
    "dev": "pnpm run predev && concurrently -k -n api,web -c blue,green \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "dev:api": "cd apps/api && go run ./cmd/server",
    "dev:web": "pnpm --dir apps/web dev",
    "build": "pnpm run build:api && pnpm run build:web",
    "build:api": "cd apps/api && go build -o ../../bin/api ./cmd/server",
    "build:web": "pnpm --dir apps/web build",
    "lint": "pnpm run lint:web",
    "lint:web": "pnpm --dir apps/web lint",
    "format": "pnpm --dir apps/web format",
    "typecheck": "pnpm --dir apps/web typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.17.1"
}
