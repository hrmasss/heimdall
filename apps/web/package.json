{
  "name": "@heimdall/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "preview": "node scripts/preview-prerendered.mjs",
    "lint": "biome check .",
    "lint:dashboard": "biome check src/components/app/dashboard.tsx src/components/app/dashboard-context.ts src/components/app/search-command.tsx src/lib/display-density.tsx src/pages/dashboard/layout.tsx src/pages/dashboard/overview.tsx src/pages/dashboard/analytics.tsx src/pages/dashboard/new-post.tsx src/pages/dashboard/calendar.tsx src/index.css",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@remixicon/react": "^4.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.513.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "5.4.296",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.7.1",
    "react-router": "^7.13.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.0",
    "simple-icons": "^16.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
